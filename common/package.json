{
  "name": "@venuepass/common",
  "version": "1.0.31",
  "description": "Shared common package for VenuePass application",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build/**/*"
  ],
  "scripts": {
    "build": "yarn clean && tsc",
    "clean": "del ./build/*",
    "sync-readme-version": "node scripts/sync-readme-version.js",
    "prepublishOnly": "yarn build",
    "release:patch": "yarn version --patch && yarn sync-readme-version && yarn publish --new-version $(node -p \"require('./package.json').version\")"
  },
  "keywords": [],
  "author": "ahsan2882",
  "license": "MIT",
  "devDependencies": {
    "del-cli": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "cookie-session": "^2.1.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "nats": "^2.29.3"
  },
  "packageManager": "yarn@1.22.22"
}
